{
  "name": "@renovatebot/ruby-semver",
  "version": "0.0.0-semantic-release",
  "description": "Ruby SemVer in TypeScript.",
  "repository": {
    "type": "git",
    "url": "https://github.com/renovatebot/ruby-semver.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "/dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "eslint": "eslint .",
    "eslint-fix": "eslint . --fix",
    "vitest": "vitest run",
    "vitest-debug": "vitest --inspect-brk --no-file-parallelism",
    "lint": "run-s eslint markdown-lint prettier",
    "lint-fix": "run-s eslint-fix markdown-lint-fix prettier-fix",
    "markdown-lint": "markdownlint-cli2",
    "markdown-lint-fix": "markdownlint-cli2-fix",
    "prepack": "run-s build",
    "prepare": "run-s \"prepare:*\"",
    "prepare:husky": "husky",
    "prettier": "prettier --check --ignore-unknown \"**/*.*\"",
    "prettier-fix": "prettier --write --ignore-unknown \"**/*.*\"",
    "test": "run-s lint type-check vitest",
    "type-check": "tsc"
  },
  "devDependencies": {
    "@containerbase/eslint-plugin": "2.1.1",
    "@containerbase/semantic-release-pnpm": "1.4.1",
    "@eslint/js": "10.0.1",
    "@tsconfig/node22": "22.0.5",
    "@types/eslint-config-prettier": "6.11.3",
    "@types/node": "22.19.19",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-formatter-gha": "2.0.1",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-promise": "7.3.0",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "markdownlint-cli2": "0.22.1",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.3",
    "prettier-plugin-packagejson": "3.0.2",
    "semantic-release": "25.0.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": "^22.11.0 || >=24.10.0",
    "pnpm": ">=10.0.0"
  }
}
